import torch
import torch.nn as nn
import numpy as np
import matplotlib.pyplot as plt
from torch.utils.data import DataLoader, TensorDataset

# Set random seed for reproducibility
torch.manual_seed(42)
np.random.seed(42)

# Device setup (important for Colab GPU)
device = torch.device("cuda" if torch.cuda.is_available() else "cpu")

print(f"PyTorch Version : {torch.__version__}")
print(f"NumPy Version   : {np.__version__}")
print(f"Device in use   : {device}")

  SEED = 42
torch.manual_seed(SEED)
np.random.seed(SEED)

# Model parameters
SEQ_LEN     = 20
INPUT_SIZE  = 1
HIDDEN_SIZE = 64
NUM_LAYERS  = 2
OUTPUT_SIZE = 1
DROPOUT     = 0.2

# Training parameters
BATCH_SIZE  = 32
EPOCHS      = 100
LR          = 0.001
TRAIN_SPLIT = 0.8

# Extra (for GPU reproducibility)
if torch.cuda.is_available():
    torch.cuda.manual_seed_all(SEED)

print("Hyperparameters set ")

  def generate_timeseries(n=1000):
    x = np.linspace(0, 8 * np.pi, n)
    data = np.sin(x) + 0.5 * np.sin(2 * x) + 0.1 * np.random.randn(n)
    return data.astype(np.float32)

# Generate data
series = generate_timeseries(1000)

# Plot
plt.figure(figsize=(12, 3))
plt.plot(series, linewidth=1.2)
plt.title("Generated Time Series (sin(x) + 0.5·sin(2x) + noise)")
plt.xlabel("Time Step")
plt.ylabel("Value")
plt.grid(True, alpha=0.3)
plt.tight_layout()
plt.show()

print(f"Series shape: {series.shape}")
print(f"Min: {series.min():.3f}, Max: {series.max():.3f}")

def create_sequences(data, seq_len):
    X, y = [], []
    
    for i in range(len(data) - seq_len):
        X.append(data[i : i + seq_len])   # input window
        y.append(data[i + seq_len])       # next value
    
    X = np.array(X, dtype=np.float32)
    y = np.array(y, dtype=np.float32)
    
    #  IMPORTANT: reshape for LSTM → (samples, seq_len, input_size)
    X = np.expand_dims(X, axis=2)
    
    return X, y

# Create sequences
X_all, y_all = create_sequences(series, SEQ_LEN)

print(f"Total sequences : {len(X_all)}")
print(f"X shape         : {X_all.shape}  → (samples, seq_len, input_size)")
print(f"y shape         : {y_all.shape}  → (samples,)")

print(f"\nExample → X[0][:5]: {X_all[0][:5].flatten()}  →  y[0]: {y_all[0]:.4f}")

# Train-test split
split = int(len(X_all) * TRAIN_SPLIT)

#  DO NOT unsqueeze X (already has correct shape)
X_train = torch.tensor(X_all[:split], dtype=torch.float32)
X_test  = torch.tensor(X_all[split:], dtype=torch.float32)

# y needs shape (N, 1)
y_train = torch.tensor(y_all[:split], dtype=torch.float32).unsqueeze(-1)
y_test  = torch.tensor(y_all[split:], dtype=torch.float32).unsqueeze(-1)

# DataLoaders
train_loader = DataLoader(
    TensorDataset(X_train, y_train),
    batch_size=BATCH_SIZE,
    shuffle=True
)

test_loader = DataLoader(
    TensorDataset(X_test, y_test),
    batch_size=BATCH_SIZE,
    shuffle=False
)

# Debug prints
print(f"Train samples : {len(X_train)}  |  Test samples : {len(X_test)}")
print(f"X_train shape : {X_train.shape}  → (samples, seq_len, input_size)")
print(f"y_train shape : {y_train.shape}")
print(f"Train batches : {len(train_loader)}  |  Test batches : {len(test_loader)}")

class RNNPredictor(nn.Module):
    """
    Stacked Vanilla RNN → Linear output head
    Input  : (batch, seq_len, 1)
    Output : (batch, 1)
    """
    def __init__(self, input_size, hidden_size, num_layers,
                 output_size, dropout):
        super(RNNPredictor, self).__init__()

        self.hidden_size = hidden_size
        self.num_layers  = num_layers

        self.rnn = nn.RNN(
            input_size=input_size,
            hidden_size=hidden_size,
            num_layers=num_layers,
            batch_first=True,
            dropout=dropout if num_layers > 1 else 0,
            nonlinearity="tanh"
        )

        self.fc = nn.Linear(hidden_size, output_size)

    def forward(self, x):
        #  Better way: create hidden state on same device automatically
        h0 = torch.zeros(self.num_layers, x.size(0), self.hidden_size, device=x.device)

        out, _ = self.rnn(x, h0)       # (batch, seq_len, hidden)
        last = out[:, -1, :]           # last time step
        out = self.fc(last)            # (batch, 1)

        return out


# Initialize model
model = RNNPredictor(
    INPUT_SIZE,
    HIDDEN_SIZE,
    NUM_LAYERS,
    OUTPUT_SIZE,
    DROPOUT
).to(device)

# Print model
print(model)

# Count parameters
total = sum(p.numel() for p in model.parameters() if p.requires_grad)
print(f"\nTrainable Parameters: {total:,}")

criterion = nn.MSELoss()

optimizer = torch.optim.Adam(model.parameters(), lr=LR)

#  FIX: removed verbose=True
scheduler = torch.optim.lr_scheduler.ReduceLROnPlateau(
    optimizer,
    mode="min",
    patience=10,
    factor=0.5
)

print("Loss      : nn.MSELoss()")
print(f"Optimizer : Adam  (lr={LR})")
print("Scheduler : ReduceLROnPlateau  (patience=10, factor=0.5)")

  def train_one_epoch(model, loader, criterion, optimizer):
    model.train()
    total_loss = 0.0

    for X_batch, y_batch in loader:
        X_batch = X_batch.to(device)
        y_batch = y_batch.to(device)

        optimizer.zero_grad()

        preds = model(X_batch)
        loss = criterion(preds, y_batch)

        loss.backward()

        # Gradient clipping (good practice)
        nn.utils.clip_grad_norm_(model.parameters(), max_norm=1.0)

        optimizer.step()

        total_loss += loss.item() * X_batch.size(0)

    return total_loss / len(loader.dataset)


def evaluate_model(model, loader, criterion):
    model.eval()
    total_loss = 0.0
    preds_all, targets_all = [], []

    with torch.no_grad():
        for X_batch, y_batch in loader:
            X_batch = X_batch.to(device)
            y_batch = y_batch.to(device)

            preds = model(X_batch)

            loss = criterion(preds, y_batch)
            total_loss += loss.item() * X_batch.size(0)

            preds_all.append(preds.cpu().numpy())
            targets_all.append(y_batch.cpu().numpy())

    avg_loss = total_loss / len(loader.dataset)

    return avg_loss, np.concatenate(preds_all), np.concatenate(targets_all)


# ── Training Loop ──────────────────────────────────────
train_losses, test_losses = [], []

print(f"{'Epoch':>6}  {'Train MSE':>12}  {'Test MSE':>12}  {'LR':>10}")
print("-" * 50)

for epoch in range(1, EPOCHS + 1):

    tr_loss = train_one_epoch(model, train_loader, criterion, optimizer)
    te_loss, _, _ = evaluate_model(model, test_loader, criterion)

    train_losses.append(tr_loss)
    test_losses.append(te_loss)

    # Scheduler step (correct usage)
    old_lr = optimizer.param_groups[0]['lr']
    scheduler.step(te_loss)
    new_lr = optimizer.param_groups[0]['lr']

    #  Print LR change manually
    if new_lr != old_lr:
        print(f" LR reduced: {old_lr:.6f} → {new_lr:.6f}")

    # Print progress
    if epoch % 10 == 0 or epoch == 1:
        print(f"{epoch:>6}  {tr_loss:>12.6f}  {te_loss:>12.6f}  {new_lr:>10.6f}")

print("\n Training Complete!")

  # Get predictions
_, test_preds, test_targets = evaluate_model(model, test_loader, criterion)

# Ensure correct shape (flatten to 1D)
test_preds = test_preds.flatten()
test_targets = test_targets.flatten()

# Metrics
mse  = np.mean((test_preds - test_targets) ** 2)
rmse = np.sqrt(mse)
mae  = np.mean(np.abs(test_preds - test_targets))

# R² Score (safe calculation)
ss_res = np.sum((test_targets - test_preds) ** 2)
ss_tot = np.sum((test_targets - np.mean(test_targets)) ** 2)

# Avoid division by zero
r2 = 1 - (ss_res / ss_tot) if ss_tot != 0 else 0.0

# Print results
print("=" * 44)
print("      EVALUATION RESULTS  (Test Set)")
print("=" * 44)
print(f"  MSE  (Mean Squared Error)        : {mse:.6f}")
print(f"  RMSE (Root Mean Squared Error)   : {rmse:.6f}")
print(f"  MAE  (Mean Absolute Error)       : {mae:.6f}")
print(f"  R²   (Coefficient of Determin.)  : {r2:.6f}")
print("=" * 44)

  plt.figure(figsize=(10, 4))

# Convert to numpy (safe for plotting)
train_losses_np = np.array(train_losses)
test_losses_np  = np.array(test_losses)

# Plot
plt.plot(train_losses_np, label="Train Loss", linewidth=2)
plt.plot(test_losses_np,  label="Test Loss", linestyle="--", linewidth=2)

# Labels and title
plt.title("Training vs Test Loss (MSE per Epoch)", fontsize=13)
plt.xlabel("Epoch")
plt.ylabel("MSE Loss")

# Legend and grid
plt.legend()
plt.grid(True, alpha=0.3)

# Better scaling (auto-adjust for visibility)
plt.ylim(
    min(train_losses_np.min(), test_losses_np.min()) * 0.9,
    max(train_losses_np.max(), test_losses_np.max()) * 1.1
)

plt.tight_layout()
plt.show()

  n_show = min(200, len(test_targets))

# Ensure correct shape
actual = test_targets[:n_show].flatten()
pred   = test_preds[:n_show].flatten()

plt.figure(figsize=(12, 4))

# Plot lines
plt.plot(actual, label="Actual", linewidth=2)
plt.plot(pred,   label="Predicted", linestyle="--", linewidth=2, alpha=0.85)

# Titles and labels
plt.title(f"Actual vs Predicted — First {n_show} Test Samples", fontsize=13)
plt.xlabel("Time Step")
plt.ylabel("Value")

# Legend and grid
plt.legend()
plt.grid(True, alpha=0.3)

# Auto scaling for better visualization
y_min = min(actual.min(), pred.min())
y_max = max(actual.max(), pred.max())
plt.ylim(y_min * 1.1 if y_min < 0 else y_min * 0.9,
         y_max * 1.1)

# Metrics box (clean formatting)
plt.text(
    0.01, 0.06,
    f"RMSE = {rmse:.4f}\nMAE  = {mae:.4f}\nR²   = {r2:.4f}",
    transform=plt.gca().transAxes,
    fontsize=10,
    bbox=dict(boxstyle="round,pad=0.4",
              facecolor="white",
              edgecolor="gray")
)

plt.tight_layout()
plt.show()

  # ================= SAVE MODEL =================
model_path = "rnn_timeseries.pth"

torch.save(model.state_dict(), model_path)
print(f"Model saved → {model_path} ")


# ================= LOAD MODEL =================
loaded_model = RNNPredictor(
    INPUT_SIZE,
    HIDDEN_SIZE,
    NUM_LAYERS,
    OUTPUT_SIZE,
    DROPOUT
).to(device)

#  Safe loading (important for different devices)
state_dict = torch.load(model_path, map_location=device)
loaded_model.load_state_dict(state_dict)

loaded_model.eval()
print("Model reloaded successfully ")


# ================= SINGLE PREDICTION =================
sample_input = X_test[0].unsqueeze(0).to(device)  # (1, seq_len, 1)

with torch.no_grad():
    pred_val = loaded_model(sample_input).item()

actual_val = y_test[0].item()

print("\n Sample Prediction Test")
print("-" * 35)
print(f"Predicted Value : {pred_val:.4f}")
print(f"Actual Value    : {actual_val:.4f}")
print(f"Absolute Error  : {abs(pred_val - actual_val):.4f}")
