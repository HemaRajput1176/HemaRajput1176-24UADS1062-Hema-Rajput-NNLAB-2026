        normal_prob    = probs[0]

        if pneumonia_prob >= threshold:
            prediction = 'PNEUMONIA'
            confidence = pneumonia_prob * 100
        else:
            prediction = 'NORMAL'
            confidence = normal_prob * 100

        return {
            'prediction'     : prediction,
            'confidence'     : confidence,
            'prob_normal'    : normal_prob    * 100,
            'prob_pneumonia' : pneumonia_prob * 100
        }

