# Cell 11: Grad-CAM Visualization - Medical Explainability
import torch
import torch.nn as nn
import numpy as np
import matplotlib.pyplot as plt
import matplotlib.cm as cm
from PIL import Image
from torchvision import transforms
import os

# -----------------------------------------------
# Grad-CAM Implementation
# -----------------------------------------------
class GradCAM:
    def __init__(self, model, target_layer):
        self.model       = model
        self.target_layer = target_layer
        self.gradients   = None
        self.activations = None

        # Register hooks
        self.target_layer.register_forward_hook(self._save_activation)
        self.target_layer.register_full_backward_hook(self._save_gradient)

    def _save_activation(self, module, input, output):
        self.activations = output.detach()

    def _save_gradient(self, module, grad_input, grad_output):
        self.gradients = grad_output[0].detach()

    def generate(self, input_tensor, class_idx=None):
        self.model.eval()
        output = self.model(input_tensor)

        if class_idx is None:
            class_idx = output.argmax(dim=1).item()

        self.model.zero_grad()
        one_hot = torch.zeros_like(output)
        one_hot[0][class_idx] = 1
        output.backward(gradient=one_hot)

        # Pool gradients
        pooled_grads = self.gradients.mean(dim=[0, 2, 3])

        # Weight activations
        cam = self.activations[0].clone()
        for i in range(cam.shape[0]):
            cam[i] *= pooled_grads[i]

        cam = cam.mean(dim=0)
        cam = torch.relu(cam)

        # Normalize
        cam = cam - cam.min()
        if cam.max() > 0:
            cam = cam / cam.max()

        return cam.cpu().numpy(), class_idx

# -----------------------------------------------
# Setup Grad-CAM on last conv layer of ResNet50
# -----------------------------------------------
gradcam = GradCAM(model, model.layer4[-1])

# -----------------------------------------------
# Transform for inference
# -----------------------------------------------
transform = transforms.Compose([
    transforms.Resize((224, 224)),
    transforms.ToTensor(),
    transforms.Normalize(mean=[0.485, 0.456, 0.406],
                         std=[0.229, 0.224, 0.225])
])

class_names = ['NORMAL', 'PNEUMONIA']

# -----------------------------------------------
# Select sample images: 2 NORMAL + 2 PNEUMONIA
# -----------------------------------------------
data_root     = './chest_xray/test'
sample_images = []

for class_name in class_names:
    class_dir = os.path.join(data_root, class_name)
    files     = sorted(os.listdir(class_dir))[:2]
    for f in files:
        sample_images.append((os.path.join(class_dir, f), class_name))

# -----------------------------------------------
# Plot Grad-CAM Results
# -----------------------------------------------
fig, axes = plt.subplots(4, 3, figsize=(14, 18))
fig.suptitle('Grad-CAM Medical Explainability\nWhat the model sees in Chest X-Rays',
             fontsize=14, fontweight='bold')

for idx, (img_path, actual_class) in enumerate(sample_images):

    # Load original image
    orig_img    = Image.open(img_path).convert('RGB')
    orig_resized = orig_img.resize((224, 224))
    orig_array  = np.array(orig_resized) / 255.0

    # Prepare tensor
    img_tensor  = transform(orig_img).unsqueeze(0).to(device)
    img_tensor.requires_grad = True

    # Generate Grad-CAM
    cam, pred_idx = gradcam.generate(img_tensor)

    # Resize CAM to image size
    from PIL import Image as PILImage
    cam_resized = np.array(
        PILImage.fromarray((cam * 255).astype(np.uint8)).resize(
            (224, 224), PILImage.BILINEAR
        )
    ) / 255.0

    # Create heatmap overlay
    heatmap     = cm.jet(cam_resized)[:, :, :3]
    overlay     = 0.5 * orig_array + 0.5 * heatmap
    overlay     = np.clip(overlay, 0, 1)

    pred_label  = class_names[pred_idx]
    correct     = pred_label == actual_class
    color       = 'green' if correct else 'red'

    row = idx

    # Column 0: Original X-ray
    axes[row][0].imshow(orig_array, cmap='gray')
    axes[row][0].set_title(f'Original X-Ray\nActual: {actual_class}',
                            fontsize=10, fontweight='bold')
    axes[row][0].axis('off')

    # Column 1: Grad-CAM Heatmap
    axes[row][1].imshow(np.mean(orig_array, axis=2), cmap='gray')
    axes[row][1].imshow(cam_resized, cmap='jet', alpha=0.5)
    axes[row][1].set_title(f'Grad-CAM Heatmap\nPred: {pred_label}',
                            fontsize=10, color=color, fontweight='bold')
    axes[row][1].axis('off')

    # Column 2: Overlay
    axes[row][2].imshow(overlay)
    axes[row][2].set_title(f'Overlay\n{"CORRECT" if correct else "WRONG"}',
                            fontsize=10, color=color, fontweight='bold')
    axes[row][2].axis('off')

plt.tight_layout()
plt.savefig('gradcam_explainability.png', dpi=150, bbox_inches='tight')
plt.show()

print("=" * 55)
print("  Grad-CAM Explainability Complete!")
print("=" * 55)
print("  Red/Yellow regions = areas model focused on")
print("  Blue regions       = areas model ignored")
print("  For PNEUMONIA: model should focus on lung fields")
print("  For NORMAL   : model should show diffuse attention")
print("  File saved   : gradcam_explainability.png")
print("=" * 55)

