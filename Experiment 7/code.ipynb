# -----------------------------------------------
# Inference Function
# -----------------------------------------------
def predict_xray(image_path, model, device, threshold=0.5):
    """
    Predict NORMAL or PNEUMONIA from a chest X-ray image.
    Returns prediction, confidence, and probability scores.
    """
    transform = transforms.Compose([
        transforms.Resize((224, 224)),
        transforms.ToTensor(),
        transforms.Normalize(mean=[0.485, 0.456, 0.406],
                             std=[0.229, 0.224, 0.225])
    ])

    # Load and preprocess
    img = Image.open(image_path).convert('RGB')
    img_tensor = transform(img).unsqueeze(0).to(device)

    model.eval()
    with torch.no_grad():
        output = model(img_tensor)
        probs  = torch.softmax(output, dim=1).cpu().numpy()[0]

    pneumonia_prob = probs[1]
    normal_prob    = probs[0]

    # Use threshold for prediction (default 0.5)
    if pneumonia_prob >= threshold:
        prediction = 'PNEUMONIA'
        confidence = pneumonia_prob * 100
    else:
        prediction = 'NORMAL'
        confidence = normal_prob * 100

    return {
        'prediction'     : prediction,
        'confidence'     : confidence,
        'prob_normal'    : normal_prob * 100,
        'prob_pneumonia' : pneumonia_prob * 100
    }

