 # Cell 5: Load Pretrained ResNet50 and Modify for Medical Classification
import torch
import torch.nn as nn
from torchvision import models

# Set device
device = torch.device('cuda' if torch.cuda.is_available() else 'cpu')
print(f"Using device: {device}")

# -----------------------------------------------
# Load Pretrained ResNet50 (trained on ImageNet)
# -----------------------------------------------
model = models.resnet50(weights=models.ResNet50_Weights.IMAGENET1K_V1)

# -----------------------------------------------
# FREEZE all base layers (pretrained ImageNet weights)
# We only want to retrain the final classifier head
# -----------------------------------------------
for param in model.parameters():
    param.requires_grad = False

# -----------------------------------------------
# REPLACE the final FC layer for binary classification
# NORMAL vs PNEUMONIA (2 classes)
# Medical-grade head: Dropout to prevent overfitting
# -----------------------------------------------
num_features = model.fc.in_features  # 2048 for ResNet50

model.fc = nn.Sequential(
    nn.Linear(num_features, 512),
    nn.BatchNorm1d(512),
    nn.ReLU(),
    nn.Dropout(p=0.4),
    nn.Linear(512, 128),
    nn.BatchNorm1d(128),
    nn.ReLU(),
    nn.Dropout(p=0.3),
    nn.Linear(128, 2)   # 2 output classes: NORMAL, PNEUMONIA
)

# Only the new FC head parameters will be trained
trainable_params = sum(p.numel() for p in model.parameters() if p.requires_grad)
total_params     = sum(p.numel() for p in model.parameters())

model = model.to(device)

print(" Pretrained ResNet50 loaded and modified for medical classification!")
print(f"  Total parameters    : {total_params:,}")
print(f"  Trainable parameters: {trainable_params:,}")
print(f"  Frozen parameters   : {total_params - trainable_params:,}")
print(f"  Output classes      : NORMAL (0), PNEUMONIA (1)")
print(f"\n  Model Head Architecture:")
print(model.fc)

# Cell 6: Loss Function, Optimizer and Scheduler
import torch.optim as optim

# -----------------------------------------------
# Class weights to handle imbalance
# Train → NORMAL: 1341, PNEUMONIA: 3875
# Pneumonia cases are ~3x more → weight NORMAL higher
# -----------------------------------------------
normal_count    = 1341
pneumonia_count = 3875
total           = normal_count + pneumonia_count

weight_normal    = total / (2 * normal_count)
weight_pneumonia = total / (2 * pneumonia_count)

class_weights = torch.tensor([weight_normal, weight_pneumonia], dtype=torch.float).to(device)

# Weighted CrossEntropy — critical for medical imbalanced data
criterion = nn.CrossEntropyLoss(weight=class_weights)

# -----------------------------------------------
# Optimizer: Only train the new FC head (frozen base)
# Adam with weight decay to prevent overfitting
# -----------------------------------------------
optimizer = optim.Adam(
    filter(lambda p: p.requires_grad, model.parameters()),
    lr=1e-3,
    weight_decay=1e-4
)

# -----------------------------------------------
# Scheduler: Reduce LR when val loss plateaus
# Prevents overshooting and helps convergence
# -----------------------------------------------
scheduler = optim.lr_scheduler.ReduceLROnPlateau(
    optimizer,
    mode='min',
    factor=0.5,
    patience=2,
    
)

print(" Loss function, Optimizer and Scheduler ready!")
print(f"  Criterion  : CrossEntropyLoss with class weights")
print(f"  Weight NORMAL    : {weight_normal:.4f}")
print(f"  Weight PNEUMONIA : {weight_pneumonia:.4f}")
print(f"  Optimizer  : Adam (lr=1e-3, weight_decay=1e-4)")
print(f"  Scheduler  : ReduceLROnPlateau (patience=2, factor=0.5)")

